# ============================================
# OpenClaw Workspace .gitignore
# ============================================

# -------------------- System Generated --------------------
# Logs
.clawdbot/logs/
*.log
logs/

# Temporary files
.clawdbot/.prompt-*
.clawdbot/.retry-prompt-*
.clawdbot/.notify-pending.txt
.clawdbot/.test-prompt.md
tmp/

# -------------------- Assets --------------------
# Generated images (archived in assets/)
*.png
*.jpg
*.jpeg
*.gif
*.webp

# -------------------- OpenClaw Runtime --------------------
.openclaw/
.clawhub/
.claude/

# -------------------- Personal Context --------------------
# User-specific files (should be in separate repo)
AGENTS.md
BOOTSTRAP.md
HEARTBEAT.md
IDENTITY.md
SOUL.md
USER.md
TOOLS.md
COMPACT_POLICY.md
memory/

# Secrets
.github-token
*.key
*.pem
*.env
.env.*
!.env.example

# -------------------- Node.js --------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
dist/
build/
out/
*.tsbuildinfo

# -------------------- Python --------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg
*.egg-info/
dist/
build/
*.whl
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# -------------------- IDEs --------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -------------------- Project Specific --------------------
# Skills (managed separately)
skills/*/node_modules/
skills/*/venv/

# Demo content (large files)
demo-video/node_modules/
demo-video/out/

# Archived projects
projects/archived/

# Star Office UI
projects/Star-Office-UI/venv/
projects/Star-Office-UI/state.json
projects/Star-Office-UI/*.log
projects/Star-Office-UI/.screenshots/

# Telegram config (contains tokens)
.clawdbot/config/telegram-agents.json

# -------------------- Git --------------------
# Keep .git subdirectories for subprojects
!projects/*/.git
!claude-Reconstruction/.git
