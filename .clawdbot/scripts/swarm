#!/bin/bash
# swarm - Agent Swarm 系统主入口

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLAWDBOT_ROOT="$SCRIPT_DIR/.clawdbot"

# 确保脚本可执行
chmod +x "$CLAWDBOT_ROOT/scripts"/*.sh 2>/dev/null

show_banner() {
    cat <<'EOF'
╔═══════════════════════════════════════════════════════╗
║           🤖 Agent Swarm System v1.0                 ║
║     OpenClaw + Codex/Claude Agent Orchestration      ║
╚═══════════════════════════════════════════════════════╝
EOF
}

cmd_spawn() {
    echo "=== Spawn New Agent ==="
    echo ""
    
    # 交互式输入
    read -p "Task ID (e.g., feat-billing): " task_id
    read -p "Agent type (codex/claude/gemini): " agent_type
    read -p "Description: " description
    read -p "Prompt file (optional, press Enter to skip): " prompt_file
    
    # 验证输入
    if [ -z "$task_id" ] || [ -z "$agent_type" ] || [ -z "$description" ]; then
        echo "Error: All fields are required (except prompt file)"
        exit 1
    fi
    
    # 如果没有 prompt file，让用户输入 prompt
    if [ -z "$prompt_file" ]; then
        echo ""
        echo "Enter your prompt (press Ctrl+D when done):"
        echo "---"
        prompt_file="$CLAWDBOT_ROOT/.prompt-$task_id.txt"
        cat > "$prompt_file"
        echo "---"
    fi
    
    # 生成 agent
    "$CLAWDBOT_ROOT/scripts/spawn-agent.sh" "$task_id" "$agent_type" "$description" "$prompt_file"
    
    echo ""
    echo "Agent spawned! Use 'swarm status' to check progress."
}

cmd_spawn_eng() {
    "$CLAWDBOT_ROOT/scripts/spawn-with-config.sh" "$@"
}

cmd_setup_integration() {
    echo "=== Setting up Claude Reconstruction Integration ==="
    echo ""
    
    local claude_recon_path="$SCRIPT_DIR/claude-Reconstruction"
    
    # Check if already exists
    if [ -d "$claude_recon_path" ]; then
        echo "✓ Claude Reconstruction already installed at: $claude_recon_path"
    else
        echo "Claude Reconstruction not found. Would you like to clone it?"
        read -p "Clone from GitHub? (y/n) " -n 1 -r
        echo ""
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            echo "Cloning Claude Reconstruction..."
            git clone https://github.com/Arxchibobo/claude-Reconstruction.git "$claude_recon_path"
            echo "✓ Cloned successfully"
        else
            echo "Skipped. You can clone it manually later:"
            echo "  cd ~/.openclaw/workspace"
            echo "  git clone https://github.com/Arxchibobo/claude-Reconstruction.git"
            return
        fi
    fi
    
    # Install dependencies
    if [ -f "$claude_recon_path/package.json" ]; then
        echo ""
        echo "Installing dependencies..."
        cd "$claude_recon_path"
        
        if command -v pnpm &> /dev/null; then
            pnpm install && pnpm install:config
        elif command -v npm &> /dev/null; then
            npm install && npm run install:config
        else
            echo "⚠ npm/pnpm not found. Please install dependencies manually."
        fi
        
        cd "$SCRIPT_DIR"
    fi
    
    echo ""
    echo "✓ Integration setup complete!"
    echo ""
    echo "Next steps:"
    echo "  1. Read integration docs: cat .clawdbot/INTEGRATION.md"
    echo "  2. Spawn engineering agent: swarm spawn-eng"
    echo ""
}

cmd_integration_status() {
    echo "=== Integration Status ==="
    echo ""
    
    local integration_config="$CLAWDBOT_ROOT/config/integration.json"
    local claude_recon_path="$SCRIPT_DIR/claude-Reconstruction"
    
    # Check config
    if [ -f "$integration_config" ]; then
        echo "✓ Integration config exists"
        local enabled=$(jq -r '.claudeReconstruction.enabled' "$integration_config")
        echo "  Enabled: $enabled"
    else
        echo "✗ Integration config not found"
    fi
    
    # Check Claude Reconstruction
    if [ -d "$claude_recon_path" ]; then
        echo "✓ Claude Reconstruction installed"
        echo "  Path: $claude_recon_path"
        
        if [ -f "$claude_recon_path/CLAUDE.md" ]; then
            echo "  Config: ✓ CLAUDE.md found"
        fi
    else
        echo "✗ Claude Reconstruction not installed"
        echo "  Run: swarm setup-integration"
    fi
    
    # Check Claude CLI
    if command -v claude &> /dev/null; then
        echo "✓ Claude CLI installed"
        echo "  Version: $(claude --version 2>&1)"
    else
        echo "✗ Claude CLI not installed"
    fi
    
    echo ""
}

cmd_status() {
    "$CLAWDBOT_ROOT/scripts/task-manager.sh" list
}

cmd_logs() {
    "$CLAWDBOT_ROOT/scripts/task-manager.sh" logs "$@"
}

cmd_attach() {
    "$CLAWDBOT_ROOT/scripts/task-manager.sh" attach "$@"
}

cmd_steer() {
    "$CLAWDBOT_ROOT/scripts/task-manager.sh" steer "$@"
}

cmd_check() {
    echo "Running monitor check..."
    "$CLAWDBOT_ROOT/scripts/check-agents.sh"
}

cmd_kill() {
    "$CLAWDBOT_ROOT/scripts/task-manager.sh" kill "$@"
}

cmd_cleanup() {
    "$CLAWDBOT_ROOT/scripts/task-manager.sh" cleanup
}

cmd_config() {
    local config_file="$CLAWDBOT_ROOT/config/swarm-config.json"
    
    if command -v jq &> /dev/null; then
        echo "Current configuration:"
        jq '.' "$config_file"
    else
        cat "$config_file"
    fi
    
    echo ""
    echo "Config file: $config_file"
    echo "Edit with: nano $config_file"
}

cmd_install_cron() {
    echo "Installing cron job for agent monitoring..."
    
    local check_script="$CLAWDBOT_ROOT/scripts/check-agents.sh"
    local cron_line="*/10 * * * * $check_script >> $CLAWDBOT_ROOT/logs/cron.log 2>&1"
    
    # 检查是否已存在
    if crontab -l 2>/dev/null | grep -q "check-agents.sh"; then
        echo "Cron job already exists!"
        return
    fi
    
    # 添加 cron job
    (crontab -l 2>/dev/null; echo "$cron_line") | crontab -
    
    echo "✓ Cron job installed: runs every 10 minutes"
    echo "To view cron logs: tail -f $CLAWDBOT_ROOT/logs/cron.log"
}

cmd_uninstall_cron() {
    echo "Removing cron job..."
    crontab -l 2>/dev/null | grep -v "check-agents.sh" | crontab -
    echo "✓ Cron job removed"
}

cmd_help() {
    show_banner
    cat <<EOF

Usage: swarm <command> [arguments]

🚀 Core Commands:
  spawn               Spawn a new agent (interactive)
  spawn-eng           Spawn an engineering agent (with Claude Reconstruction)
  status              List all active tasks
  check               Run monitor check manually
  
🔧 Integration:
  setup-integration   Setup Claude Reconstruction integration
  integration-status  Check integration status
  
📊 Task Management:
  logs <task-id>      View task logs
  attach <task-id>    Attach to agent's tmux session
  steer <task-id> <msg>  Send steering message to agent
  kill <task-id>      Kill a running task
  cleanup             Clean up completed tasks
  
⚙️  Configuration:
  config              View/edit configuration
  install-cron        Install monitoring cron job (every 10 min)
  uninstall-cron      Remove monitoring cron job
  
📚 Help:
  help                Show this help message

Examples:
  swarm spawn                       # Start a new agent (interactive)
  swarm spawn-eng                   # Start with engineering config
  swarm status                      # Check all tasks
  swarm logs feat-billing           # View logs
  swarm steer feat-billing "Stop. Focus on API first."
  swarm attach feat-billing         # Attach to tmux session
  swarm install-cron                # Enable automatic monitoring
  swarm setup-integration           # Setup Claude Reconstruction

Integration with Claude Reconstruction:
  - Intelligent context management (20% vs 60% context usage)
  - 5-layer engineering system
  - Plan-Confirm-Execute-Deliver workflow
  - Automated rule enforcement
  
For more info: 
  - Agent Swarm: cat .clawdbot/README.md
  - Integration: cat .clawdbot/INTEGRATION.md
  - Claude Reconstruction: cat claude-Reconstruction/README.md
EOF
}

# 主命令分发
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    spawn)              cmd_spawn "$@" ;;
    spawn-eng)          cmd_spawn_eng "$@" ;;
    setup-integration)  cmd_setup_integration "$@" ;;
    integration-status) cmd_integration_status "$@" ;;
    status)             cmd_status "$@" ;;
    logs)               cmd_logs "$@" ;;
    attach)             cmd_attach "$@" ;;
    steer)              cmd_steer "$@" ;;
    check)              cmd_check "$@" ;;
    kill)               cmd_kill "$@" ;;
    cleanup)            cmd_cleanup "$@" ;;
    config)             cmd_config "$@" ;;
    install-cron)       cmd_install_cron "$@" ;;
    uninstall-cron)     cmd_uninstall_cron "$@" ;;
    help|--help|-h)     cmd_help ;;
    *)
        echo "Unknown command: $COMMAND"
        echo "Run 'swarm help' for usage"
        exit 1
        ;;
esac
